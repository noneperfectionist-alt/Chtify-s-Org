{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the Nexora platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string", "description": "Globally unique username" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "userType": { "type": "string", "enum": ["normal", "special_atithi", "admin"], "description": "Type of user" },
        "isApproved": { "type": "boolean", "description": "Approval status for special atithi" },
        "emailVerified": { "type": "boolean", "description": "Whether email is verified" },
        "profilePhoto": { "type": "string", "description": "URL to profile photo" },
        "status": { "type": "string", "enum": ["available", "not_available"], "description": "User availability status" },
        "publicKey": { "type": "string", "description": "Public encryption key" },
        "fcmTokens": { "type": "array", "items": { "type": "string" }, "description": "List of FCM device tokens" },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "showPreview": { "type": "boolean", "description": "Whether to show message preview in push" },
            "soundEnabled": { "type": "boolean", "description": "Whether to enable notification sound" },
            "vibrationEnabled": { "type": "boolean", "description": "Whether to enable vibration" }
          },
          "description": "User's notification preferences"
        },
        "otp": { "type": "string", "description": "Verification OTP" },
        "otpCreatedAt": { "type": "string", "format": "date-time", "description": "OTP creation timestamp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "username", "email", "userType"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "Represents a friend request between users.",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "toUid", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Represents a chat message.",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "receiverUid": { "type": "string" },
        "content": { "type": "string", "description": "Encrypted message content" },
        "type": { "type": "string", "enum": ["text", "voice", "image", "video", "location"] },
        "status": { "type": "string", "enum": ["sent", "delivered", "seen"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderUid", "receiverUid", "content", "type"]
    },
    "Log": {
      "title": "Log",
      "description": "System activity log.",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "details": { "type": "string" },
        "type": { "type": "string", "enum": ["security", "info", "warning", "success"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "type", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "User moderation report.",
      "type": "object",
      "properties": {
        "reporterUid": { "type": "string" },
        "reportedUid": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterUid", "reportedUid", "reason", "status", "createdAt"]
    },
    "Blog": {
      "title": "Blog",
      "description": "Represents a blog post.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string", "description": "URL to blog image" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Represents a support request from the help center.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Friend requests"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    },
    "/cinema_chats/{chatId}": {
      "schema": "object",
      "description": "Cinema room chat messages"
    },
    "/admin_config/settings": {
      "schema": "object",
      "description": "Admin panel configuration and security"
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "System activity logs"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Moderation reports"
    },
    "/blogs/{blogId}": {
      "schema": "Blog",
      "description": "Blog posts"
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Support tickets from help center"
    }
  }
}
